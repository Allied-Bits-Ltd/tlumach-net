<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
    <metadata>
        <id>AlliedBits.Tlumach.Writers</id>
        <version>1.5.0</version>
        <authors>Eugene Mayevski</authors>
        <copyright>Allied Bits Ltd.</copyright>
        <license type="expression">Apache-2.0</license>
        <licenseUrl>https://licenses.nuget.org/Apache-2.0</licenseUrl>
        <icon>Tlumach.Writers.png</icon>
        <title>The translation and localization package for .NET</title>
        <tags>tlumach translation localization</tags>
        <repository type="git" url="https://github.com/Allied-Bits-Ltd/tlumach-net" commit="c7a8eba771ff41aa776bc0ef92edb81c0380d4f2" />
        <projectUrl>https://alliedbits.com/tlumach</projectUrl>
        <readme>README.writers.nuget.md</readme>
        <description>
        This package contains writer classes for Tlumach.NET. These classes can be used to export translations and convert them between translation file formats.
    </description>
        <dependencies>
            <dependency id="AlliedBits.Tlumach" version="1.5.0" exclude="Build,Analyzers" />
            <group targetFramework=".NETStandard2.0">
                <dependency id="NETStandard.Library" version="2.0.3" exclude="Build,Analyzers" />
                <dependency id="System.Memory" version="4.6.3"  exclude="Build,Analyzers" />
                <dependency id="System.Text.Json" version="10.0.0" exclude="Build,Analyzers" />
            </group>
            <group targetFramework="net9.0">
            </group>
            <group targetFramework="net9.0-windows10.0.19041.0">
            </group>
            <group targetFramework="net9.0-windows10.0.26100.0">
            </group>
            <group targetFramework="net9.0-android21.0">
            </group>
            <group targetFramework="net9.0-ios15.0">
            </group>
            <group targetFramework="net9.0-maccatalyst15.0">
            </group>
            <group targetFramework="net10.0">
            </group>
            <group targetFramework="net10.0-windows10.0.19041.0">
            </group>
            <group targetFramework="net10.0-windows10.0.26100.0">
            </group>
            <group targetFramework="net10.0-android21.0">
            </group>
            <group targetFramework="net10.0-ios15.0">
            </group>
            <group targetFramework="net10.0-maccatalyst15.0">
            </group>
        </dependencies>
    </metadata>
    <files>
        <file src="README.writers.nuget.md" target="\" />
        <file src="Tlumach.Writers.png" target="\" />

