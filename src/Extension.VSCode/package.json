{
  "name": "tlumach-generator",
  "displayName": "Tlumach.NET Generator",
  "description": "Runs the Tlumach.NET source generator on demand for translation configuration files marked as 'C# Analyzer additional file' in your projects.",
  "version": "1.6.0",
  "publisher": "AlliedBits",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "translation",
    "localization",
    "i18n",
    "l10n",
    "Tlumach",
    "source generator",
    "code generation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Allied-Bits-ltd/tlumach-net"
  },
  "icon": "icon.png",
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "tlumach.runGenerator",
        "title": "Run Tlumach Generator",
        "category": "Tlumach"
      },
      {
        "command": "tlumach.runGeneratorAllProjects",
        "title": "Run Tlumach Generator (All Projects)",
        "category": "Tlumach"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "tlumach.runGenerator",
          "when": "resourceExtname == .csproj",
          "group": "tlumach@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && dotnet publish runner/Runner.csproj -c Release -o runner/bin/publish --no-self-contained",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build-runner": "dotnet build runner/Runner.csproj -c Release"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
