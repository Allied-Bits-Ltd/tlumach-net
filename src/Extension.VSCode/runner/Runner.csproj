<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net9.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <LangVersion>latest</LangVersion>
        <AssemblyName>Runner</AssemblyName>
        <RootNamespace>AlliedBits.Tlumach.Extension.VSCode.Runner</RootNamespace>
        <IsPackable>false</IsPackable>
        <!-- Produce a single self-describing output directory for the extension to bundle -->
        <PublishSingleFile>false</PublishSingleFile>
        <!-- Exclude debug symbols and XML docs from the published output -->
        <DebugType>None</DebugType>
        <DebugSymbols>false</DebugSymbols>
        <GenerateDocumentationFile>false</GenerateDocumentationFile>
        <AllowedReferenceRelatedFileExtensions>.dll</AllowedReferenceRelatedFileExtensions>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\Tlumach.Generator\Tlumach.Generator.csproj"
                          ReferenceOutputAssembly="true" />
        <!-- Microsoft.CodeAnalysis.CSharp has PrivateAssets="all" in the Generator project,
             so it does not flow here. Add it explicitly for CSharpGeneratorDriver usage and
             to ensure the assemblies are present in the published output. -->
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.0.0" />
    </ItemGroup>

    <ItemGroup>
      <AdditionalFiles Include="..\..\Shared\stylecop.json" />
    </ItemGroup>

</Project>
